local function getTorso()
    local char = LP.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
        or char:FindFirstChild("Torso")
        or char:FindFirstChild("UpperTorso")
end

local function getPosition(v)
    if v.ClassName == "Model" then
        return v.PrimaryPart and v.PrimaryPart.Position or nil
    end
    return v.Position
end

local function getSword()
    local playerFolder = workspace:FindFirstChild(LP.Name)
    if not playerFolder then return nil end
    local swordFolder = playerFolder:FindFirstChild("Sword")
    if not swordFolder then return nil end
    return swordFolder:FindFirstChild("Handle")
end

local function getWhisperParticipants(channel)
    local names = {}
    local ok, children = pcall(function() return channel:GetChildren() end)
    if not ok or not children then return names end

    for _, src in ipairs(children) do
        local okIsSrc, isSrc = pcall(function() return src:IsA("TextSource") end)
        if okIsSrc and isSrc then
            local okName, name = pcall(function() return src.Name end)
            if okName and name then
                table.insert(names, name)
            end
        end
    end
    return names
end

local function getPrivateChannelPartner(channel, ownerName)
    local ok, children = pcall(function() return channel:GetChildren() end)
    if not ok or not children then return nil end

    for _, src in ipairs(children) do
        local okIsSrc, isSrc = pcall(function() return src:IsA("TextSource") end)
        if okIsSrc and isSrc then
            local okName, name = pcall(function() return src.Name end)
            if okName and name and name ~= ownerName then
                return name
            end
        end
    end
    return nil
end

