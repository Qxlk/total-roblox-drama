--  COIN HUNT 
task.spawn(function()
    local trackedCoins = {}
    while true do
        task.wait(1)
        if not coinCollect then trackedCoins = {} continue end

        local assets = workspace:FindFirstChild("Assets")
        if not assets then continue end
        local coinHuntFolder = assets:FindFirstChild("Coin Hunt")
        if not coinHuntFolder then continue end
        local coinsFolder = coinHuntFolder:FindFirstChild("Coins")
        if not coinsFolder then continue end

        local torso = getTorso()
        if not torso then continue end

        local gems, coins = {}, {}
        for _, v in pairs(coinsFolder:GetChildren()) do
            if v.Name == "Gem" then table.insert(gems, v)
            else table.insert(coins, v) end
        end

        local targets = #gems > 0 and gems or coins
        local label   = #gems > 0 and "Gem" or "Coin"

        for _, v in pairs(targets) do
            local pos = getPosition(v)
            if not pos then continue end
            local key = label .. "_" .. tostring(pos.X):sub(1, 8)
            if not trackedCoins[key] then
                trackedCoins[key] = true
                if v.ClassName == "Model" and v.PrimaryPart then
                    v:SetPrimaryPartCFrame(torso.CFrame)
                elseif v.ClassName ~= "Model" then
                    v.CFrame = torso.CFrame
                end
                task.wait(0.1)
            end
        end
    end
end)

--  MATH MANIA 
task.spawn(function()
    local lastEnter = false
    local firstShown = false
    while true do
        task.wait(0.05)
        if not mathEnabled then
            firstShown = false
            continue
        end

        local assets = workspace:FindFirstChild("Assets")
        if not assets then continue end
        local mathFolder = assets:FindFirstChild("Math Mania")
        if not mathFolder then continue end
        local questionsFolder = mathFolder:FindFirstChild("Questions")
        if not questionsFolder then continue end

        local questionFolder = questionsFolder:FindFirstChild(tostring(currentQuestion))
        if not questionFolder then
            continue
        end

        local answerValue = questionFolder:FindFirstChild("answer")
        if not answerValue then
            continue
        end

        if not firstShown then
            notify("Answer: " .. tostring(answerValue.Value), "Math Mania - Question" .. currentQuestion, 5)
            print("Question" .. currentQuestion .. " -> Answer: " .. tostring(answerValue.Value))
            currentQuestion += 1
            firstShown = true
            continue
        end

        local enterNow = iskeypressed(VK_ENTER)
        if enterNow and not lastEnter then
            local nextFolder = questionsFolder:FindFirstChild(tostring(currentQuestion))
            if not nextFolder then
                lastEnter = enterNow
                continue
            end
            local nextAnswer = nextFolder:FindFirstChild("answer")
            if nextAnswer then
                notify("Answer: " .. tostring(nextAnswer.Value), "Math Mania - Question" .. currentQuestion, 5)
                print("Question" .. currentQuestion .. " -> Answer: " .. tostring(nextAnswer.Value))
                currentQuestion += 1
            end
        end
        lastEnter = enterNow
    end
end)

--  SWORD 
task.spawn(function()
    local killed = {}
    while true do
        task.wait(1)
        if getSword() then break end
    end

    while true do
        task.wait(0.1)
        if not swordEnabled then continue end

        local sword = getSword()
        if not sword then
            while true do
                task.wait(1)
                if getSword() then break end
            end
            continue
        end

        local target = nil
        for _, player in pairs(game:GetService("Players"):GetPlayers()) do
            if player.Name == LP.Name then continue end
            if killed[player.Name] then continue end
            local char = player.Character
            if not char then continue end
            local hum = char:FindFirstChild("Humanoid")
            if not hum or hum.Health <= 0 then continue end
            local torsoTarget = char:FindFirstChild("HumanoidRootPart")
                or char:FindFirstChild("Torso")
                or char:FindFirstChild("UpperTorso")
            if not torsoTarget then continue end
            target = { player = player, hum = hum, torso = torsoTarget }
            break
        end

        if not target then task.wait(2) continue end

        local lastHp = target.hum.Health
        while swordEnabled do
            task.wait(0.05)
            sword = getSword()
            if not sword then break end

            local char = target.player.Character
            if not char then killed[target.player.Name] = true break end

            local hum = char:FindFirstChild("Humanoid")
            if not hum or hum.Health <= 0 then
                killed[target.player.Name] = true
                break
            end

            local torsoTarget = char:FindFirstChild("HumanoidRootPart")
                or char:FindFirstChild("Torso")
                or char:FindFirstChild("UpperTorso")
            if not torsoTarget then continue end

            lastHp = hum.Health
            sword.CFrame = CFrame.new(torsoTarget.Position.X, torsoTarget.Position.Y, torsoTarget.Position.Z)
        end
    end
end)

-- ESP
local function createESPOnce(instance, label, color)
    local hit = instance:FindFirstChild("hit")
    if not hit then return end

    local outline = Drawing.new("Square")
    outline.Thickness = 3
    outline.Color = Color3.fromRGB(0, 0, 0)
    outline.Filled = false
    outline.Visible = false

    local box = Drawing.new("Square")
    box.Thickness = 1
    box.Color = color
    box.Filled = false
    box.Visible = false

    local text = Drawing.new("Text")
    text.Text = label
    text.Color = color
    text.Outline = true
    text.Center = true
    text.Size = 14
    text.Visible = false

    local elapsed = 0
    while elapsed < 2 do
        if not instance.Parent then break end
        hit = instance:FindFirstChild("hit")
        if not hit then break end

        if espEnabled then
            local top, on1    = WorldToScreen(hit.Position + Vector3.new(0, 2, 0))
            local bottom, on2 = WorldToScreen(hit.Position - Vector3.new(0, 2, 0))
            if on1 and on2 then
                local h = math.abs(top.Y - bottom.Y)
                local w = h
                box.Position     = Vector2.new(top.X - w / 2, top.Y)
                box.Size         = Vector2.new(w, h)
                outline.Position = Vector2.new(top.X - w / 2, top.Y)
                outline.Size     = Vector2.new(w, h)
                text.Position    = Vector2.new(top.X, top.Y - 16)
                box.Visible     = true
                outline.Visible = true
                text.Visible    = true
            else
                box.Visible     = false
                outline.Visible = false
                text.Visible    = false
            end
        else
            box.Visible     = false
            outline.Visible = false
            text.Visible    = false
        end

        task.wait(0.05)
        elapsed += 0.05
    end

    outline:Remove()
    box:Remove()
    text:Remove()
end

local function watchObject(instance, label, color)
    task.spawn(function()
        while instance.Parent do
            createESPOnce(instance, label, color)
        end
    end)
end

--  MAIN LOOP 
local tracked = {}

while true do
    task.wait(1)
    local idols = workspace:FindFirstChild("Idols")
    if not idols then tracked = {} continue end

    for _, v in pairs(idols:GetDescendants()) do
        local hit = v:FindFirstChild("hit")
        if (v.Name == "Bag" or v.Name == "SafetyStatue") and hit then
            local key = v.Name .. "_" .. tostring(hit.Position.X):sub(1, 6)

            if autoCollect then
                local torso = getTorso()
                if torso then torso.CFrame = hit.CFrame end
            end

            if not tracked[key] then
                tracked[key] = true
                local label = v.Name == "Bag" and "Bag" or "Statue"
                local color = v.Name == "Bag" and COLORS.Bag or COLORS.SafetyStatue
                print(string.format("Found %s at: %.1f, %.1f, %.1f", label, hit.Position.X, hit.Position.Y, hit.Position.Z))
                watchObject(v, label, color)
            end
        end
    end
end
