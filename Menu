            for _, part in pairs(team:GetChildren()) do
                if part.Name:lower() == LP.Name:lower() then
                    pancake = part
                    break
                end
            end
            if pancake then break end
        end

        if not pancake then continue end

        local torso = getTorso()
        if not torso then continue end

        local look = torso.CFrame.LookVector
        local offset = 3
        torso.CFrame = CFrame.new(
            pancake.Position.X - look.X * offset,
            pancake.Position.Y,
            pancake.Position.Z - look.Z * offset
        ) * CFrame.Angles(0, math.atan2(-look.X, -look.Z), 0)

        local screenPos, onScreen = WorldToScreen(pancake.Position)
        if not onScreen then continue end

        local dx = screenPos.X - mouse.X
        local dy = screenPos.Y - mouse.Y
        mousemoverel(dx, dy)
        mouse1press()
        mouse1release()
    end
end)

-- SWORD
task.spawn(function()
    local killed = {}
    while true do
        task.wait(1)
        if getSword() then break end
    end

    while true do
        task.wait(0.1)
        if not swordEnabled then continue end

        local sword = getSword()
        if not sword then
            while true do
                task.wait(1)
                if getSword() then break end
            end
            continue
        end

        local target = nil
        for _, player in pairs(game:GetService("Players"):GetPlayers()) do
            if player.Name == LP.Name then continue end
            if killed[player.Name] then continue end
            local char = player.Character
            if not char then continue end
            local hum = char:FindFirstChild("Humanoid")
            if not hum or hum.Health <= 0 then continue end
            local torsoTarget = char:FindFirstChild("HumanoidRootPart")
                or char:FindFirstChild("Torso")
                or char:FindFirstChild("UpperTorso")
            if not torsoTarget then continue end
            target = { player = player, hum = hum, torso = torsoTarget }
            break
        end

        if not target then task.wait(2) continue end

        local lastHp = target.hum.Health
        while swordEnabled do
            task.wait(0.05)
            sword = getSword()
            if not sword then break end

            local char = target.player.Character
            if not char then killed[target.player.Name] = true break end

            local hum = char:FindFirstChild("Humanoid")
            if not hum or hum.Health <= 0 then
                killed[target.player.Name] = true
                break
            end

            local torsoTarget = char:FindFirstChild("HumanoidRootPart")
                or char:FindFirstChild("Torso")
                or char:FindFirstChild("UpperTorso")
            if not torsoTarget then continue end

            lastHp = hum.Health
            sword.CFrame = CFrame.new(torsoTarget.Position.X, torsoTarget.Position.Y, torsoTarget.Position.Z)
        end
    end
end)

-- VOTE
task.spawn(function()
    local knownVotes       = {}
    local lastNotifiedRound = 0
    while true do
        task.wait(1)
        if not voteNotifyEnabled then continue end

        local ok, votingPlayers = pcall(function()
            return game.ReplicatedStorage.Season.Voting.Players
        end)
        if not ok or not votingPlayers then continue end

        for _, playerFolder in ipairs(votingPlayers:GetChildren()) do
            local ok2, store = pcall(function()
                return game.Workspace.Chart.ChartGui.Store.Players
            end)
            if not ok2 or not store then continue end

            local fullFolder = store:FindFirstChild(playerFolder.Name)
            if not fullFolder then continue end

            local votesFolder = fullFolder:FindFirstChild("Votes")
            if not votesFolder or not votesFolder:IsA("Folder") then continue end

            local highestRound, highestVal = nil, nil
            for _, voteValue in ipairs(votesFolder:GetChildren()) do
                if not voteValue:IsA("StringValue") then continue end
                local roundNum = tonumber(voteValue.Name)
                if not roundNum then continue end
                local valStr = tostring(voteValue.Value or "")
                if valStr == "" or valStr == "-" or valStr:lower() == "safe" then continue end
                if not highestRound or roundNum > highestRound then
                    highestRound = roundNum
                    highestVal   = valStr
                end
            end

            if highestRound and highestRound > lastNotifiedRound then
                local key = playerFolder.Name
                if knownVotes[key] ~= highestVal then
                    knownVotes[key] = highestVal
                    notify(playerFolder.Name, "Round " .. highestRound .. ": voted " .. highestVal, 16)
                    print(playerFolder.Name .. " voted " .. highestVal .. " (Round " .. highestRound .. ")")
                end
            end
        end
    end
end)

