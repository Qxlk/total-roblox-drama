task.spawn(function()
    while true do
        task.wait(0.01)
        if not pancakeEnabled then continue end

        local assets = workspace:FindFirstChild("Assets")
        if not assets then continue end
        local pancakeEating = assets:FindFirstChild("Pancake Eating")
